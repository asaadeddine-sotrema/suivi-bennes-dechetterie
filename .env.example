# === Base de données ===
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://sotrema:change-me@postgres:5432/sotrema_bennes

# === Application ===
ENVIRONMENT=production
SECRET_KEY=change-me
# Seuil d'alerte par défaut (%) si aucun seuil n'est paramétré pour une benne
ALERTE_SEUIL=75

# === Synchronisation Kizeo par email (Microsoft Graph / Outlook) ===
# Laisser vide pour désactiver la synchronisation (import PDF manuel uniquement).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
OUTLOOK_USER_EMAIL=

# Planificateur de synchronisation automatique.
# SYNC_ENABLED=true démarre une synchro périodique (uniquement si les 4 variables
# Azure/Outlook ci-dessus sont renseignées).
SYNC_ENABLED=false
SYNC_INTERVAL_MINUTES=15
